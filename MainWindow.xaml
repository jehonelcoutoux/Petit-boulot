<Window x:Class="PtiBoulot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P'tiBoulot - Connexion"
        Width="1000" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="/logo.ico">

        

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANNEAU GAUCHE : Formulaire -->
        <Border Grid.Column="0" Background="White" Padding="40">
            <StackPanel VerticalAlignment="Center">

                <!-- Logo -->
                <TextBlock Text="🧰 P'tiBoulot" FontSize="24" FontWeight="Bold"
                           Foreground="#1E293B" Margin="0,0,0,4"/>
                <TextBlock Text="Services locaux au Gabon" FontSize="13"
                           Foreground="#64748B" Margin="0,0,0,40"/>

                <!-- Titre -->
                <TextBlock Text="Bon retour ! 👋" FontSize="22" FontWeight="Bold"
                           Foreground="#1E293B" Margin="0,0,0,6"/>
                <TextBlock Text="Connectez-vous pour accéder à votre espace"
                           FontSize="13" Foreground="#64748B" Margin="0,0,0,28"/>

                <!-- Email -->
                <TextBlock Text="EMAIL" FontSize="11" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtEmail" Height="42" Padding="12,10"
                         FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                         Margin="0,0,0,16"/>

                <!-- Mot de passe -->
                <TextBlock Text="MOT DE PASSE" FontSize="11" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtPassword" Height="42" Padding="12,10"
                             FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                             Margin="0,0,0,8"/>

                <!-- Message erreur -->
                <TextBlock x:Name="TxtErreur" Foreground="#EF4444"
                           FontSize="13" Margin="0,0,0,12"
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <!-- Bouton connexion -->
                <Button x:Name="BtnConnecter" Content="Se connecter →"
                        Height="44" FontSize="14" FontWeight="SemiBold"
                        Background="#22C55E" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnConnecter_Click" Margin="0,0,0,14"/>

                <!-- Lien inscription -->
                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Pas de compte ? " Foreground="#64748B" FontSize="13"/>
                    <Hyperlink x:Name="LinkInscription" Click="LinkInscription_Click"
                               Foreground="#22C55E" TextDecorations="None">
                        <Run Text="Créer un compte" FontSize="13" FontWeight="SemiBold"/>
                    </Hyperlink>
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- PANNEAU DROIT : Présentation -->
        <Border Grid.Column="1" Background="#F0FDF4">
            <StackPanel VerticalAlignment="Center" Margin="60,0">
                <TextBlock Text="Trouvez le bon" FontSize="36" FontWeight="Bold"
                           Foreground="#1E293B"/>
                <TextBlock Text="prestataire" FontSize="36" FontWeight="Bold"
                           Foreground="#22C55E"/>
                <TextBlock Text="rapidement" FontSize="36" FontWeight="Bold"
                           Foreground="#1E293B" Margin="0,0,0,16"/>
                <TextBlock TextWrapping="Wrap" MaxWidth="380" FontSize="14"
                           Foreground="#64748B" Margin="0,0,0,32"
                           Text="P'tiBoulot connecte clients et prestataires locaux à travers tout le Gabon. Simple, rapide et sécurisé."/>

                <!-- Stats -->
                <StackPanel Orientation="Horizontal">
                    <Border Background="White" CornerRadius="8" Padding="20,14" Margin="0,0,10,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="500+" FontSize="20" FontWeight="Bold"
                                       Foreground="#22C55E" HorizontalAlignment="Center"/>
                            <TextBlock Text="Prestataires" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20,14" Margin="0,0,10,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="1000+" FontSize="20" FontWeight="Bold"
                                       Foreground="#3B82F6" HorizontalAlignment="Center"/>
                            <TextBlock Text="Missions" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20,14">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="4.8★" FontSize="20" FontWeight="Bold"
                                       Foreground="#F59E0B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Note moy." FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>