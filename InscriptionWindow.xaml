<Window x:Class="PtiBoulot.InscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P'tiBoulot - Inscription"
        Width="1000" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
         Icon="logo.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANNEAU GAUCHE -->
        <Border Grid.Column="0" Background="White" Padding="40">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Center">

                    <!-- Logo -->
                    <TextBlock Text="🧰 P'tiBoulot" FontSize="24" FontWeight="Bold"
                               Foreground="#1E293B" Margin="0,0,0,4"/>
                    <TextBlock Text="Services locaux au Gabon" FontSize="13"
                               Foreground="#64748B" Margin="0,0,0,30"/>

                    <!-- Titre -->
                    <TextBlock Text="Créer un compte 🎉" FontSize="22" FontWeight="Bold"
                               Foreground="#1E293B" Margin="0,0,0,6"/>
                    <TextBlock Text="Rejoignez la communauté P'tiBoulot"
                               FontSize="13" Foreground="#64748B" Margin="0,0,0,24"/>

                    <!-- Nom complet -->
                    <TextBlock Text="NOM COMPLET" FontSize="10" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtNom" Height="42" Padding="12,10"
                             FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1"
                             Background="#F8FAFC" Margin="0,0,0,14"/>

                    <!-- Email -->
                    <TextBlock Text="EMAIL" FontSize="10" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtEmail" Height="42" Padding="12,10"
                             FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1"
                             Background="#F8FAFC" Margin="0,0,0,14"/>

                    <!-- Mot de passe -->
                    <TextBlock Text="MOT DE PASSE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="TxtPassword" Height="42" Padding="12,10"
                                 FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1"
                                 Margin="0,0,0,14"/>

                    <!-- Ville -->
                    <TextBlock Text="VILLE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtVille" Height="42" Padding="12,10"
                             FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1"
                             Background="#F8FAFC" Margin="0,0,0,14"/>

                    <!-- Rôle -->
                    <TextBlock Text="JE SUIS UN(E)" FontSize="10" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton x:Name="RbClient" Content="👤  Client"
                                     GroupName="Role" IsChecked="True"
                                     FontSize="14" Padding="16,10"
                                     BorderThickness="1" BorderBrush="#E2E8F0"
                                     Background="#F8FAFC" Cursor="Hand"
                                     Checked="RbRole_Checked"/>
                        <RadioButton x:Name="RbPrestataire" Content="🔧  Prestataire"
                                     GroupName="Role"
                                     FontSize="14" Padding="16,10"
                                     BorderThickness="1" BorderBrush="#E2E8F0"
                                     Background="#F8FAFC" Cursor="Hand"
                                     Margin="10,0,0,0"
                                     Checked="RbRole_Checked"/>
                    </StackPanel>

                    <!-- Champs prestataire -->
                    <StackPanel x:Name="PanelPrestataire" Visibility="Collapsed">
                        <TextBlock Text="COMPÉTENCES" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtCompetences" Height="42" Padding="12,10"
                                 FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1"
                                 Background="#F8FAFC" Margin="0,0,0,14"/>

                        <TextBlock Text="TARIF HORAIRE (FCFA)" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtTarif" Height="42" Padding="12,10"
                                 FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1"
                                 Background="#F8FAFC" Margin="0,0,0,14"/>
                    </StackPanel>

                    <!-- Erreur -->
                    <TextBlock x:Name="TxtErreur" Foreground="#EF4444" FontSize="13"
                               Margin="0,0,0,10" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Bouton -->
                    <Button Content="Créer mon compte →" Height="46"
                            FontSize="14" FontWeight="SemiBold"
                            Background="#22C55E" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Margin="0,0,0,16" Click="BtnInscrire_Click"/>

                    <!-- Lien connexion -->
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="Déjà un compte ? " Foreground="#64748B" FontSize="13"/>
                        <Hyperlink Click="LinkConnexion_Click"
                                   Foreground="#22C55E" TextDecorations="None">
                            <Run Text="Se connecter" FontSize="13" FontWeight="SemiBold"/>
                        </Hyperlink>
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- PANNEAU DROIT -->
        <Border Grid.Column="1" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#16A34A" Offset="0"/>
                    <GradientStop Color="#0EA5E9" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" Margin="50,0">
                <TextBlock Text="Rejoignez" FontSize="36" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="P'tiBoulot" FontSize="36" FontWeight="Bold"
                           Foreground="#DCFCE7"/>
                <TextBlock Text="dès aujourd'hui !" FontSize="36" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,16"/>
                <TextBlock TextWrapping="Wrap" MaxWidth="340" FontSize="14"
                           Foreground="#DCFCE7" Margin="0,0,0,32"
                           Text="Que vous soyez client ou prestataire, P'tiBoulot vous connecte aux meilleures opportunités au Gabon."/>

                <!-- Avantages -->
                <StackPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#16A34A" Margin="0,0,12,0">
                            <TextBlock Text="✓" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Inscription gratuite et rapide" Foreground="White"
                                   FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#16A34A" Margin="0,0,12,0">
                            <TextBlock Text="✓" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Accès à des centaines de missions" Foreground="White"
                                   FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="28" Height="28" CornerRadius="14"
                                Background="#16A34A" Margin="0,0,12,0">
                            <TextBlock Text="✓" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Paiement sécurisé en FCFA" Foreground="White"
                                   FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>